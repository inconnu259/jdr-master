generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum GlobalRole {
  USER
  ADMIN
}

/// Compte utilisateur. La connexion se fait par `email` ; `pseudo` est public (recherche/affichage).
model User {
  id           String     @id @default(uuid())
  email        String     @unique
  pseudo       String     @unique
  passwordHash String
  role         GlobalRole @default(USER)
  createdAt    DateTime   @default(now())
}
