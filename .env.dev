# === Base de données (PostgreSQL) ===
POSTGRES_USER=jdr
POSTGRES_PASSWORD=changeme
POSTGRES_DB=jdr

# URL utilisée par l'API / Prisma (hôte "db" = nom du service docker-compose)
DATABASE_URL=postgresql://jdr:changeme@db:5432/jdr?schema=public

# === API (NestJS) ===
API_PORT=3000
WEB_ORIGIN=http://localhost:4200

# === Auth / session ===
SESSION_SECRET=dev-secret-change-me-please
# Premier compte admin (créé par le seed)
ADMIN_EMAIL=admin@master-jdr.local
ADMIN_PSEUDO=admin
ADMIN_PASSWORD=change-me-admin

# === Web (Angular) ===
WEB_PORT=4200
API_URL=http://localhost:3000
