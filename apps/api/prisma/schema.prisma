generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum GlobalRole {
  USER
  ADMIN
}

/// Compte utilisateur. La connexion se fait par `email` ; `pseudo` est public (recherche/affichage).
model User {
  id           String     @id @default(uuid())
  email        String     @unique
  pseudo       String     @unique
  passwordHash String
  role         GlobalRole @default(USER)
  createdAt    DateTime   @default(now())

  mjOfParties              Partie[]                  @relation("PartieMJ")
  memberships              Membership[]
  invitesSent              Invitation[]              @relation("InvitationInviter")
  invitesRecv              Invitation[]              @relation("InvitationInvitee")
  inviteLinksCreated       InviteLink[]              @relation("InviteLinkCreator")
  availabilityDeclarations AvailabilityDeclaration[]
  pollVotes                PollVote[]
  characters               Character[]
  passwordResetTokens      PasswordResetToken[]
  xpDistributionsGiven     XpDistribution[]          @relation("XpDistributionMj")
  inscriptions             Inscription[]
  scenarioParticipations   ScenarioParticipant[]
}

enum PartieKind {
  ONE_SHOT
  CAMPAGNE_LINEAIRE
  CAMPAGNE_EPISODIQUE
}

/// Une partie (one-shot ou campagne). Le MJ = le créateur (`mjId`) ; les joueurs sont des `Membership`.
model Partie {
  id           String     @id @default(uuid())
  name         String
  kind         PartieKind
  gameSystemId String
  description  String?
  mjId         String
  mj           User       @relation("PartieMJ", fields: [mjId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  nextSessionDate DateTime? // Date confirmée de la prochaine séance (mise à jour par Epic 3)
  nextSessionSlot DaySlot? // Créneau confirmé
  reminderSentAt  DateTime? // null = rappel pas encore envoyé pour le créneau courant (Epic 5)

  memberships       Membership[]
  invitations       Invitation[]
  inviteLinks       InviteLink[]
  polls             SessionPoll[]
  characters        Character[]
  xpDistributions   XpDistribution[]
  scenarios         Scenario[]
  scenarioDocuments ScenarioDocument[]
  announcements     Announcement[]
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  REVOKED
}

/// Un JOUEUR dans une partie (le MJ n'est pas un membership, il est `Partie.mjId`).
model Membership {
  id       String   @id @default(uuid())
  userId   String
  partieId String
  joinedAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  partie   Partie   @relation(fields: [partieId], references: [id], onDelete: Cascade)

  @@unique([userId, partieId])
}

/// Invitation ciblée d'un utilisateur DÉJÀ inscrit (accept/refus in-app).
model Invitation {
  id            String           @id @default(uuid())
  partieId      String
  partie        Partie           @relation(fields: [partieId], references: [id], onDelete: Cascade)
  inviterId     String
  inviter       User             @relation("InvitationInviter", fields: [inviterId], references: [id], onDelete: Cascade)
  inviteeUserId String
  invitee       User             @relation("InvitationInvitee", fields: [inviteeUserId], references: [id], onDelete: Cascade)
  status        InvitationStatus @default(PENDING)
  createdAt     DateTime         @default(now())
  respondedAt   DateTime?

  @@unique([partieId, inviteeUserId])
}

/// Lien d'invitation = aussi le SEUL moyen de s'inscrire (inscription sur invitation).
model InviteLink {
  id          String   @id @default(uuid())
  token       String   @unique
  partieId    String
  partie      Partie   @relation(fields: [partieId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User     @relation("InviteLinkCreator", fields: [createdById], references: [id], onDelete: Cascade)
  maxUses     Int? // null = illimité · 1 = usage unique · N = X joueurs
  usesCount   Int      @default(0)
  expiresAt   DateTime // défaut +7 jours, configurable
  revoked     Boolean  @default(false)
  createdAt   DateTime @default(now())
  targetEmail String? // renseigné uniquement pour un lien généré via l'invitation par e-mail (Story 5.2) ; null = lien ouvert partageable
}

/// Jeton de réinitialisation de mot de passe (self-service, Story 5.4). Usage unique, expire à +24h.
model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// ─── Palier 2 : Calendrier de disponibilités ──────────────────────────────────

enum DaySlot {
  MORNING
  AFTERNOON
  EVENING
  FULL_DAY
}

enum RecurKind {
  RECURRING
  PUNCTUAL
}

enum AvailKind {
  UNAVAILABLE
  AVAILABLE
}

enum PollStatus {
  OPEN
  CLOSED
}

enum VoteAnswer {
  YES
  NO
  MAYBE
}

/// Déclaration de disponibilité ou d'indisponibilité d'un utilisateur.
/// Portée globale (pas par partie). Expiration obligatoire.
/// Soft-delete = expiresAt mis à now() (archivage par expiration).
model AvailabilityDeclaration {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind      AvailKind
  recurKind RecurKind
  dayOfWeek Int? // 0=dim … 6=sam, obligatoire si RECURRING
  slot      DaySlot   @default(FULL_DAY)
  startDate DateTime? // obligatoire si PUNCTUAL
  endDate   DateTime? // obligatoire si PUNCTUAL
  expiresAt DateTime // archivé quand expiresAt <= now()
  createdAt DateTime  @default(now())

  @@index([userId, expiresAt])
}

/// Vote de date lancé par le MJ pour déterminer la prochaine séance.
model SessionPoll {
  id          String       @id @default(uuid())
  partieId    String
  partie      Partie       @relation(fields: [partieId], references: [id], onDelete: Cascade)
  createdById String
  scenarioRef String?
  status      PollStatus   @default(OPEN)
  expiresAt   DateTime?
  chosenDate  DateTime?
  chosenSlot  DaySlot?
  createdAt   DateTime     @default(now())
  options     PollOption[]
  votes       PollVote[]
  seance      Seance?

  @@index([partieId, status])
}

/// Option (créneau candidat) d'un vote de date.
model PollOption {
  id     String      @id @default(uuid())
  pollId String
  poll   SessionPoll @relation(fields: [pollId], references: [id], onDelete: Cascade)
  date   DateTime
  slot   DaySlot
  votes  PollVote[]
}

/// Vote d'un membre sur une option.
model PollVote {
  id       String      @id @default(uuid())
  pollId   String
  poll     SessionPoll @relation(fields: [pollId], references: [id], onDelete: Cascade)
  optionId String
  option   PollOption  @relation(fields: [optionId], references: [id], onDelete: Cascade)
  userId   String
  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  answer   VoteAnswer

  @@unique([optionId, userId])
}

// ─── Palier P3 : Moteur plugin & Ryuutama ──────────────────────────────────────

enum ContentScope {
  BASE
  MJ
  PARTIE
}

/// Système de jeu enregistré dans le registre (id = slug stable, ex: "ryuutama").
model GameSystem {
  id      String @id
  name    String
  version String

  contentTypes ContentType[]
  characters   Character[]
}

/// Type de contenu d'un système de jeu (ex: classe, type, catégorie d'arme).
model ContentType {
  id           String     @id @default(uuid())
  gameSystemId String
  gameSystem   GameSystem @relation(fields: [gameSystemId], references: [id], onDelete: Cascade)
  key          String
  label        String

  entries ContentEntry[]

  @@unique([gameSystemId, key])
}

/// Entrée de contenu (donnée data-driven) pour un ContentType donné.
model ContentEntry {
  id            String       @id @default(uuid())
  contentTypeId String
  contentType   ContentType  @relation(fields: [contentTypeId], references: [id], onDelete: Cascade)
  scope         ContentScope @default(BASE)
  key           String
  data          Json

  @@unique([contentTypeId, key])
}

/// Personnage d'un joueur (ou du MJ) pour une partie et un système de jeu donnés.
model Character {
  id                   String     @id @default(uuid())
  userId               String
  user                 User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  partieId             String
  partie               Partie     @relation(fields: [partieId], references: [id], onDelete: Cascade)
  gameSystemId         String
  gameSystem           GameSystem @relation(fields: [gameSystemId], references: [id])
  sheetData            Json
  derived              Json
  portraitUrl          String?
  portraitCropData     Json?
  pdfPortraitCropData  Json?
  xp                   Int        @default(0)
  journalAutoAssociate Boolean    @default(false)
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  xpDistributionEntries XpDistributionEntry[]
  snapshots             CharacterSnapshot[]
  notes                 CharacterNote[]

  @@unique([userId, partieId, gameSystemId])
  @@index([partieId])
  @@index([userId])
}

/// Distribution d'XP faite par le MJ après une session (Story 6.2) — historique par Partie.
model XpDistribution {
  id        String                @id @default(uuid())
  partieId  String
  partie    Partie                @relation(fields: [partieId], references: [id], onDelete: Cascade)
  mjId      String
  mj        User                  @relation("XpDistributionMj", fields: [mjId], references: [id], onDelete: Cascade)
  note      String?
  createdAt DateTime              @default(now())
  entries   XpDistributionEntry[]

  @@index([partieId, createdAt])
}

model XpDistributionEntry {
  id             String         @id @default(uuid())
  distributionId String
  distribution   XpDistribution @relation(fields: [distributionId], references: [id], onDelete: Cascade)
  characterId    String
  character      Character      @relation(fields: [characterId], references: [id], onDelete: Cascade)
  amount         Int
  isBonus        Boolean        @default(false)
}

enum SnapshotTrigger {
  LEVEL_UP
  MJ_EDIT
}

/// Instantané immuable de la fiche d'un personnage (Story 6.3), créé à chaque montée de niveau
/// (`LEVEL_UP`) ou édition MJ directe (`MJ_EDIT`, Story 6.6) — jamais de restauration (append-only).
model CharacterSnapshot {
  id          String          @id @default(uuid())
  characterId String
  character   Character       @relation(fields: [characterId], references: [id], onDelete: Cascade)
  sheetData   Json
  derived     Json
  level       Int
  trigger     SnapshotTrigger
  note        String?
  createdAt   DateTime        @default(now())

  @@index([characterId, createdAt])
}

/// Journal de notes personnelles du propriétaire d'un personnage (Story 6.5) — append-only,
/// jamais éditée/supprimée après création. `shared` bascule la visibilité par entrée (jamais un
/// réglage global) : privée par défaut (propriétaire + MJ), ou visible par tout participant de
/// la Partie une fois partagée.
model CharacterNote {
  id          String    @id @default(uuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  text        String
  shared      Boolean   @default(false)
  createdAt   DateTime  @default(now())

  @@index([characterId, createdAt])
}

/// Sessions HTTP (stockées par connect-pg-simple). Modélisées ici pour que **Prisma** les gère :
/// sinon la table créée au runtime apparaît comme un « drift » à chaque migration.
model Session {
  sid    String   @id @db.VarChar
  sess   Json     @db.Json
  expire DateTime @db.Timestamp(6)

  @@index([expire], map: "IDX_session_expire")
  @@map("session")
}

// ─── Palier 4 (suite) : Scénarios, Séances, rétrospective, annonces MJ ────────

enum ScenarioStatus {
  BROUILLON
  A_VENIR
  COURANT
  PASSE
}

/// Unité de contenu narratif d'une Partie (Story 7.1). Un one-shot = un scénario unique
/// (créé automatiquement, cf. PartiesService.create). Cycle de vie anti-spoil :
/// BROUILLON (invisible joueurs) → A_VENIR (titre+date seuls) → COURANT (contenu complet) → PASSE.
/// Pas de verrouillage optimiste (AD-3) : MJ seul écrivain de son contenu propre.
model Scenario {
  id           String         @id @default(uuid())
  partieId     String
  partie       Partie         @relation(fields: [partieId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  status       ScenarioStatus @default(BROUILLON)
  dureeHeures  Int?
  dureeSeances Int?
  resumeFin    String? // rétrospective, FR-15 (Epic 8) — champ créé maintenant, non écrit par 7.1
  createdAt    DateTime       @default(now())
  closedAt     DateTime?

  seances       Seance[]
  documents     ScenarioDocument[]
  participants  ScenarioParticipant[]
  announcements Announcement[]

  @@index([partieId, status])
}

/// Une soirée de jeu rattachée à un scénario (Epic 8, non exploité par la Story 7.1).
/// Relation vers SessionPoll (linéaire/one-shot) OU Inscription[] (épisodique), jamais les deux (AD-4).
model Seance {
  id             String       @id @default(uuid())
  scenarioId     String
  scenario       Scenario     @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  pollId         String?      @unique
  poll           SessionPoll? @relation(fields: [pollId], references: [id])
  inscriptionMin Int?
  inscriptionMax Int?
  dateValidee    DateTime?
  compteRendu    String?
  createdAt      DateTime     @default(now())

  inscriptions Inscription[]
}

/// Inscription à capacité limitée (Epic 8, Story 8.3 — campagne épisodique uniquement).
model Inscription {
  id        String   @id @default(uuid())
  seanceId  String
  seance    Seance   @relation(fields: [seanceId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([seanceId, userId])
}

/// Participation individuelle à un scénario (Epic 8, campagne épisodique uniquement — AD-4).
/// Jamais peuplé/lu pour ONE_SHOT/CAMPAGNE_LINEAIRE (participants dérivés de Membership).
model ScenarioParticipant {
  id         String   @id @default(uuid())
  scenarioId String
  scenario   Scenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([scenarioId, userId])
}

/// Document joint à un scénario (anti-spoil, Story 7.2) ou à la bibliothèque de Partie
/// (scenarioId null = toujours visible, Story 7.2). Non exploité par la Story 7.1.
model ScenarioDocument {
  id           String    @id @default(uuid())
  partieId     String
  partie       Partie    @relation(fields: [partieId], references: [id], onDelete: Cascade)
  scenarioId   String?
  scenario     Scenario? @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  filename     String
  originalName String
  sizeBytes    Int
  createdAt    DateTime  @default(now())

  @@index([partieId])
}

/// Annonce MJ à portée variable (Epic 9, Story 9.1 — non exploité par la Story 7.1).
model Announcement {
  id         String    @id @default(uuid())
  partieId   String
  partie     Partie    @relation(fields: [partieId], references: [id], onDelete: Cascade)
  scenarioId String?
  scenario   Scenario? @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  text       String
  createdAt  DateTime  @default(now())

  @@index([partieId, createdAt])
}
